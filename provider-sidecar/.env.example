# ── GOAT x402 credentials ────────────────────────────────────
# Provider credentials obtained from @goathackbot (see ID-01).
# Required for real payment verification.
GOATX402_API_URL=https://x402-api-lx58aabp0r.testnet3.goat.network
GOATX402_MERCHANT_ID=your_project
GOATX402_API_KEY=your_api_key
GOATX402_API_SECRET=your_api_secret

# ── Local LLM ────────────────────────────────────────────────
# Ollama endpoint the sidecar proxies inference requests to.
OLLAMA_ENDPOINT=http://localhost:11434

# ── Sidecar config ───────────────────────────────────────────
# Port the sidecar HTTP server listens on.
PROVIDER_PORT=4021
# Default price charged per inference request.
PRICE_AMOUNT=0.01
PRICE_SYMBOL=USDC

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug  # debug | info | warn | error

# ── Development ──────────────────────────────────────────────
# When "true", skips real x402 payment verification and accepts
# all requests as paid. Set to "false" (or remove) for production
# to require actual on-chain payments via GOAT x402.
MOCK_PAYMENTS=true
