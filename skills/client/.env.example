# ── Marketplace ───────────────────────────────────────────────
# URL of the OpenClaw marketplace API.
MARKETPLACE_URL=http://localhost:3000

# ── Wallet ───────────────────────────────────────────────────
# EVM private key used to sign on-chain payment transactions.
# Required when providers charge for inference via x402.
EVM_PRIVATE_KEY=your_private_key

# Blockchain RPC endpoint for submitting transactions.
# Defaults to GOAT testnet3 if not set.
EVM_RPC_URL=https://rpc.testnet3.goat.network
