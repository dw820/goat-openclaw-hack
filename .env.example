# ── Database ──────────────────────────────────────────────────
# Neon PostgreSQL connection string.
# When set, the marketplace uses the Neon DB store.
# When absent, it falls back to an in-memory store (fine for local dev).
# DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require

# ── Seed data ────────────────────────────────────────────────
# Pre-load a mock provider into the in-memory store on startup.
# Set to "false" to start with an empty registry.
SEED_PROVIDERS=true

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug  # debug | info | warn | error

# ── Public URLs ──────────────────────────────────────────────
# GOAT dashboard URL used for provider verification badges.
NEXT_PUBLIC_GOAT_DASHBOARD=https://goat-dashboard.vercel.app
